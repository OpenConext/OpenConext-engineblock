#!/usr/bin/env php
<?php

// This is a wrapper script that uses vendor/bin/phpunit instead of the Symfony PHPUnit Bridge
// to avoid issues with missing traits in PHPUnit 9.6.0

// Pass all arguments to vendor/bin/phpunit
$args = array_slice($argv, 1);
$command = dirname(__DIR__).'/vendor/bin/phpunit '.implode(' ', array_map('escapeshellarg', $args));

// Execute the command
passthru($command, $exitCode);
exit($exitCode);
